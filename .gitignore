# Generated experiment data (retain directory markers)
runs/*
!runs/.gitkeep
checkpoints/*
!checkpoints/.gitkeep
datasets/*
!datasets/.gitkeep

# Generated analytical laboratory outputs
lab/reports/*
!lab/reports/.gitkeep
lab/notebooks/.ipynb_checkpoints/

# Python caches and compiled files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Test, type, lint, and coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# Build and packaging outputs
build/
dist/
*.egg-info/
.eggs/

# Local environment files
.env
.env.*
!.env.example
